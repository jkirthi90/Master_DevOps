pipeline {
    agent any
//node 'worker01'
    stages {
        stage('Repo clone') {
            steps {
                echo 'This is Repo clone stage'
                sh 'rm -rf *'
                sh 'git clone -b maven https://github.com/jkirthi90/Jenkins_DevOps.git'
				  }
			}
		stage ('Build'){
		steps {
		  echo 'This is Build stage'
		  sh 'pwd'
		  sh 'hostname'
		  sh 'whoami'
		  sh 'cd myfirstrepo/my-app && mvn clean && mvn package'
		  }
		  }
		stage ('Test'){
		steps {
		  sh 'cd myfirstrepo/my-app && java -cp target/my-app-1.0-SNAPSHOT.jar com.mycompany.app.App'
		  }  
		}
		}
	}




